.layout{display:block}
.panelTitle{display:flex;justify-content:center;gap:12px;align-items:center;text-align:center;background:rgba(255,255,255,.92);border:1px solid var(--line);border-radius:24px;padding:18px 16px;margin-bottom:14px;box-shadow:var(--shadow)}
