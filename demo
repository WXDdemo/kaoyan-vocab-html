  var stars = loadObj(STORE_KEYS.stars);
  var known = loadObj(STORE_KEYS.known);
  var groupStars = loadObj(STORE_KEYS.groupStars);
  var groupKnown = loadObj(STORE_KEYS.groupKnown);
  function activeCount(obj){var n=0; for(var k in obj){if(obj[k]) n++;} return n;}
  function groupKey(mode,name){return mode+'::'+name}
  function groupFromKey(key){
    var p = String(key).indexOf('::');
    if(p < 0) return null;
    var mode = key.slice(0,p), name = key.slice(p+2), list = groups[mode] || [];
    for(var i=0;i<list.length;i++){if(list[i][0]===name) return {mode:mode,name:name,ids:list[i][1],key:key};}
    return null;
  }
  function renderStats(){
    var mastered = 0, starred = 0, masteredGroups = 0, starredGroups = 0;
    for(var k in known){if(known[k]) mastered++;}
    for(var s in stars){if(stars[s]) starred++;}
    for(var gk in groupKnown){if(groupKnown[gk]) masteredGroups++;}
    for(var gs in groupStars){if(groupStars[gs]) starredGroups++;}
    $('stats').innerHTML = '<div class="stat"><b>'+stats.words+'</b><span>去重单词</span></div>'+
      '<div class="stat"><b>'+stats.fine+'</b><span>同义/近义分类</span></div>'+
      '<div class="stat"><b>'+stats.supplemented+'</b><span>补充释义词</span></div>'+
      '<div class="stat"><b>'+(mastered+masteredGroups)+'/'+(starred+starredGroups)+'</b><span>已掌握 / 收藏</span></div>';
  }
  function groupList(){
    if(state.random){
      var pool = [];
      for(var i=0;i<words.length;i++){ pool.push(i); }
      for(var j=pool.length-1;j>0;j--){ var r=Math.floor(Math.random()*(j+1)); var t=pool[j]; pool[j]=pool[r]; pool[r]=t; }
      return [['随机 20 个', pool.slice(0,20)]];
    }
    if(state.mode==='starred'){
      var favGroups = [], fav = [];
      for(var gs in groupStars){if(groupStars[gs]){var g=groupFromKey(gs); if(g) favGroups.push([g.name, g.ids, {key:g.key, sourceMode:g.mode}]);}}
      favGroups.sort(function(a,b){return a[0].localeCompare(b[0]);});
      for(var s in stars){if(stars[s] && words[s]) fav.push(Number(s));}
      fav.sort(function(a,b){return words[a][0].localeCompare(words[b][0]);});
      if(fav.length) favGroups.push(['收藏单词', fav, {wordCollection:true}]);
      return favGroups;
    }
    if(state.mode==='known'){
      var masteredGroups = [], mastered = [];
      for(var gk in groupKnown){if(groupKnown[gk]){var kg=groupFromKey(gk); if(kg) masteredGroups.push([kg.name, kg.ids, {key:kg.key, sourceMode:kg.mode}]);}}
      masteredGroups.sort(function(a,b){return a[0].localeCompare(b[0]);});
      for(var k in known){if(known[k] && words[k]) mastered.push(Number(k));}
      mastered.sort(function(a,b){return words[a][0].localeCompare(words[b][0]);});
      if(mastered.length) masteredGroups.push(['已掌握单词', mastered, {wordCollection:true}]);
      return masteredGroups;
    }
    var list = groups[state.mode] || [];
    return list;
  }
  function shownList(){
    var list = groupList();
    if(state.mode==='fine' && !state.random) return list.slice(0,state.limit);
    return list;
  }
  function wordHtml(id){
    var w = words[id];
    if(!w) return '';
    var tag = '<span class="tag">考研词</span>' + (w[2] ? '<span class="tag sup">补充释义</span>' : '') + (known[id] ? '<span class="tag known">已掌握</span>' : '');
    return '<div class="word" id="word-'+id+'"><div class="wMain"><div class="en">'+esc(w[0])+'</div><div class="tags">'+tag+'</div><div class="actions"><button class="mini '+(stars[id]?'active':'')+'" data-act="star" data-id="'+id+'">'+(stars[id]?'★ 已收藏':'☆ 收藏')+'</button><button class="mini '+(known[id]?'active':'')+'" data-act="known" data-id="'+id+'">'+(known[id]?'✓ 已掌握':'✓ 掌握')+'</button></div></div><div class="meaning">'+esc(w[1]).replace(/\n/g,'<br>')+'</div></div>';
  }
  function renderGroups(){
    renderStats();
    var all = groupList();
    var list = shownList();
    $('modeTitle').textContent = state.random ? titles.random : titles[state.mode];
    var shownWords = 0;
    for(var c=0;c<list.length;c++) shownWords += list[c][1].length;
    $('showInfo').textContent = state.random ? '20 个词' : ('显示 '+list.length+' / '+all.length+' 类，'+shownWords+' 个词');
    var html = '';
    if(!list.length || (list.length===1 && !list[0][1].length)){
      $('groups').innerHTML = '<div class="empty">当前分类暂无单词。可以先点 ⭐ 收藏或 ✓ 掌握。</div>';
      renderLoadMore(all.length, list.length);
      return;
    }
    var label = state.random ? '随机' : (state.mode==='alpha' ? '全部' : (state.mode==='starred' ? '收藏' : (state.mode==='known' ? '已掌握' : '同义')));
    for(var i=0;i<list.length;i++){
      var name = list[i][0], ids = list[i][1], meta = list[i][2] || {}, gid = (state.random?'random':state.mode)+'_'+i;
      var isOpen = !!state.open[gid] || state.random;
      var actionMode = meta.sourceMode || state.mode;
      var gKey = meta.key || groupKey(actionMode, name);
      var groupActions = '';
      if(!state.random && !meta.wordCollection){
        groupActions = '<div class="groupActions"><button class="mini '+(groupStars[gKey]?'active':'')+'" data-act="group-star" data-gkey="'+esc(gKey)+'">'+(groupStars[gKey]?'★ 已收藏':'☆ 收藏')+'</button><button class="mini '+(groupKnown[gKey]?'active':'')+'" data-act="group-known" data-gkey="'+esc(gKey)+'">'+(groupKnown[gKey]?'✓ 已掌握':'✓ 掌握')+'</button></div>';
      }
      html += '<article class="group '+(isOpen?'open':'')+'" id="group-'+gid+'"><div class="groupHead" data-gid="'+gid+'" data-index="'+i+'" role="button" tabindex="0"><span class="arrow">›</span><div class="gBody"><div class="gTop"><span class="gName">'+esc(name)+'<span class="badge">'+label+'</span></span><span class="count">'+ids.length+' 个词</span></div>'+groupActions+'</div></div>';
      if(isOpen){
        html += '<div class="words">';
        for(var j=0;j<ids.length;j++) html += wordHtml(ids[j]);
        html += '</div>';
      }
      html += '</article>';
    }
    $('groups').innerHTML = html;
    renderLoadMore(all.length, list.length);
  }
  function renderLoadMore(total, shown){
    if(state.mode==='fine' && !state.random && shown < total) $('loadMoreBox').innerHTML = '<button class="more" id="moreBtn">再显示 180 类（'+shown+' / '+total+'）</button>';
    else $('loadMoreBox').innerHTML = '';
  }
  function closeAll(){state.open={}; renderGroups();}
  function setMode(mode){state.mode=mode; state.random=false; state.open={}; state.limit=180; var tabs=document.querySelectorAll('.tab'); for(var i=0;i<tabs.length;i++){tabs[i].className = tabs[i].getAttribute('data-mode')===mode ? 'tab active' : 'tab';} renderGroups(); window.scrollTo(0,0);}
  $('groups').onclick = function(e){
    var el = e.target;
    while(el && el !== $('groups')){
      var act = el.getAttribute && el.getAttribute('data-act');
      if(act){
        var id = el.getAttribute('data-id');
        if(act==='star'){stars[id]=!stars[id]; if(!stars[id]) delete stars[id]; saveObj(STORE_KEYS.stars,stars);}
        if(act==='known'){known[id]=!known[id]; if(!known[id]) delete known[id]; saveObj(STORE_KEYS.known,known);}
        if(act==='group-star'){var gsid=el.getAttribute('data-gkey'); groupStars[gsid]=!groupStars[gsid]; if(!groupStars[gsid]) delete groupStars[gsid]; saveObj(STORE_KEYS.groupStars,groupStars);}
        if(act==='group-known'){var gkid=el.getAttribute('data-gkey'); groupKnown[gkid]=!groupKnown[gkid]; if(!groupKnown[gkid]) delete groupKnown[gkid]; saveObj(STORE_KEYS.groupKnown,groupKnown);}
        renderGroups(); return;
      }
      var gid = el.getAttribute && el.getAttribute('data-gid');
      if(gid){ if(state.open[gid]) delete state.open[gid]; else state.open[gid]=1; renderGroups(); setTimeout(function(){var g=document.getElementById('group-'+gid); if(g) g.scrollIntoView({block:'start'});},0); return; }
      el = el.parentNode;
    }
  };
  document.querySelector('.toolbar').onclick = function(e){
    var mode = e.target.getAttribute && e.target.getAttribute('data-mode'); if(mode) setMode(mode);
  };
  $('randomBtn').onclick = function(){state.random=true; state.open={'random_0':1}; renderGroups(); window.scrollTo(0,0);};
  $('exportBtn').onclick = function(){
    var data = {
      app:'考研单词中文同义归类背诵',
      version:1,
      exportedAt:new Date().toISOString(),
      words:stats.words,
      stars:stars,
      known:known,
      groupStars:groupStars,
      groupKnown:groupKnown
    };
    var day = new Date().toISOString().slice(0,10);
    var blob = new Blob([JSON.stringify(data,null,2)], {type:'application/json;charset=utf-8'});
    var a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = '考研背词进度备份_'+day+'.json';
    document.body.appendChild(a);
    a.click();
    setTimeout(function(){URL.revokeObjectURL(a.href); a.remove();},0);
  };
  $('importBtn').onclick = function(){$('importFile').click();};
  $('importFile').onchange = function(){
    var file = this.files && this.files[0];
    if(!file) return;
    var reader = new FileReader();
    reader.onload = function(){
      try{
        var data = JSON.parse(String(reader.result || '{}'));
        stars = data.stars || {};
        known = data.known || {};
        groupStars = data.groupStars || {};
        groupKnown = data.groupKnown || {};
        saveObj(STORE_KEYS.stars,stars);
        saveObj(STORE_KEYS.known,known);
        saveObj(STORE_KEYS.groupStars,groupStars);
        saveObj(STORE_KEYS.groupKnown,groupKnown);
        state.open = {};
        renderGroups();
        alert('进度已导入：收藏 '+(activeCount(stars)+activeCount(groupStars))+'，已掌握 '+(activeCount(known)+activeCount(groupKnown))+'。');
      }catch(err){
        alert('导入失败：请选择之前导出的进度备份 JSON 文件。');
      }
      $('importFile').value = '';
    };
    reader.readAsText(file,'utf-8');
  };
  $('downloadBtn').onclick = function(){
    var blob = new Blob(['<!doctype html>\n'+document.documentElement.outerHTML], {type:'text/html;charset=utf-8'});
    var a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = '考研单词中文同义归类背诵_手机版离线版.html';
    document.body.appendChild(a);
    a.click();
    setTimeout(function(){URL.revokeObjectURL(a.href); a.remove();},0);
  };
  $('closeBtn').onclick = closeAll;
  document.body.onclick = function(e){ if(e.target && e.target.id==='moreBtn'){state.limit += 180; renderGroups();} };
  $('toTop').onclick = function(){window.scrollTo(0,0)};
  window.onscroll = function(){$('toTop').className = window.scrollY>600 ? 'floatTop show' : 'floatTop';};
  renderGroups();
})();
</script>
</body>
</html>
