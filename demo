.groupHead{width:100%;border:0;background:#fff;padding:18px 16px;display:grid;grid-template-columns:auto minmax(0,1fr);align-items:center;gap:12px;text-align:left;cursor:pointer}
.arrow{flex:0 0 auto;width:34px;height:34px;border:1px solid #bfdbfe;border-radius:999px;color:var(--blue);display:grid;place-items:center;font-size:18px;transition:.2s;background:#f8fbff}
.group.open .arrow{transform:rotate(90deg);background:#eff6ff}
.gBody{min-width:0}
.gTop{display:flex;align-items:center;gap:8px}
.gName{font-size:22px;font-weight:900;letter-spacing:0;flex:1;min-width:0;word-break:break-word}
.groupActions{display:flex;flex-wrap:wrap;gap:7px;margin-top:10px}
.badge{display:inline-flex;align-items:center;border-radius:999px;padding:6px 10px;font-size:13px;font-weight:800;background:#ecfdf5;color:#047857;margin-left:8px}
.count{font-size:16px;color:var(--muted);white-space:nowrap}
.words{border-top:1px solid var(--line);padding:0 18px 16px;background:linear-gradient(180deg,#fff,#fbfdff)}
.word{display:grid;grid-template-columns:220px 1fr;gap:12px;padding:16px 0;border-bottom:1px solid #edf0f5}
.word:last-child{border-bottom:0}
.wMain{min-width:0}.en{font-size:22px;font-weight:900;letter-spacing:.2px;word-break:break-word}
