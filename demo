.meaning{font-size:17px;line-height:1.75;color:#1f2937;white-space:normal}
.actions{display:flex;gap:7px;margin-top:10px}.mini{border:1px solid var(--line);background:#fff;border-radius:999px;padding:7px 10px;font-weight:800;color:#4b5563;cursor:pointer}.mini.active{background:#111827;color:#fff;border-color:#111827}
.empty{background:#fff;border:1px dashed #cbd5e1;border-radius:22px;padding:28px;text-align:center;color:var(--muted)}
.loadMore{text-align:center;margin:18px 0}.more{padding:13px 20px;background:#111827;color:#fff;border-color:#111827}
.floatTop{position:fixed;right:18px;bottom:22px;width:48px;height:48px;border-radius:999px;border:0;background:#111827;color:#fff;font-size:20px;box-shadow:0 12px 30px rgba(0,0,0,.18);display:none;z-index:20}
.floatTop.show{display:block}
@media (max-width:820px){
 .app{padding:12px 10px 82px}.hero{border-radius:24px;padding:24px 14px}h1{letter-spacing:0}.stats{grid-template-columns:repeat(2,1fr)}.stat{padding:12px}.stat b{font-size:22px}
