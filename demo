*{box-sizing:border-box}
html{scroll-behavior:smooth}
body{margin:0;font-family:-apple-system,BlinkMacSystemFont,"Segoe UI","PingFang SC","Microsoft YaHei",Arial,sans-serif;color:var(--text);background:linear-gradient(135deg,var(--bg1),#f8fafc 48%,var(--bg2));font-size:16px;}
button{font-family:inherit;-webkit-tap-highlight-color:transparent;touch-action:manipulation}
.app{max-width:520px;min-height:100vh;margin:0 auto;padding:18px 12px 90px}
.hero{position:relative;overflow:hidden;background:rgba(255,255,255,.88);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,.86);border-radius:30px;padding:28px 18px 22px;box-shadow:var(--shadow)}
.hero:before{content:"";position:absolute;right:-70px;top:-100px;width:360px;height:260px;border-radius:999px;background:radial-gradient(circle at 30% 30%,rgba(109,93,252,.25),rgba(20,184,166,.20),transparent 70%);filter:blur(8px)}
h1{position:relative;margin:0;text-align:center;font-size:clamp(34px,10vw,48px);line-height:1.08;letter-spacing:0}
.stats{position:relative;display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-top:24px}
.stat{background:#fff;border:1px solid var(--line);border-radius:18px;padding:14px 16px;box-shadow:0 8px 22px rgba(15,23,42,.05)}
.stat b{display:block;font-size:24px;margin-bottom:2px}.stat span{font-size:13px;color:var(--muted)}
.toolbar{position:sticky;top:0;z-index:10;margin:14px 0;background:rgba(255,255,255,.94);backdrop-filter:blur(14px);border:1px solid rgba(229,231,235,.9);border-radius:24px;box-shadow:0 12px 32px rgba(15,23,42,.08);padding:12px}
.row{display:flex;flex-wrap:nowrap;gap:10px;align-items:center;overflow-x:auto;padding-bottom:2px;scrollbar-width:none}
.row::-webkit-scrollbar{display:none}
.tab,.tool,.more{border:1px solid var(--line);background:#fff;color:#374151;border-radius:999px;padding:11px 15px;font-size:15px;font-weight:700;line-height:1;cursor:pointer}
.tab,.tool{flex:0 0 auto}
.tab.active{border-color:transparent;color:#fff;background:linear-gradient(135deg,var(--primary),var(--primary2));box-shadow:0 9px 20px rgba(109,93,252,.25)}
.tool.primary{border-color:transparent;color:#fff;background:#111827}
